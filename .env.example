# VaultFlow Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# SETUP:
#   cp .env.example .env
#   # Then fill in real values in .env (never commit .env)
#
# All values here are EXAMPLE PLACEHOLDERS — not real secrets.
# Generate real values with:
#   DB_PASSWORD=$(openssl rand -hex 24)
#   REDIS_PASSWORD=$(openssl rand -hex 24)
#   SIGNED_URL_SECRET=$(openssl rand -hex 32)
#   GRAFANA_ADMIN_PASSWORD=$(openssl rand -hex 16)
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_USERNAME=vaultflow
# Replace with a strong random value: openssl rand -hex 24
DB_PASSWORD=replace-with-strong-password

# ── Redis ─────────────────────────────────────────────────────────────────────
# Replace with a strong random value: openssl rand -hex 24
REDIS_PASSWORD=replace-with-strong-password

# ── Signed URL Secret ─────────────────────────────────────────────────────────
# HMAC-SHA256 signing key for time-limited download URLs.
# Replace with: openssl rand -hex 32
# Rotate quarterly. Rotation invalidates all existing signed URLs.
SIGNED_URL_SECRET=replace-with-64-char-hex-string

# ── Grafana ───────────────────────────────────────────────────────────────────
# Admin password for the Grafana dashboard at http://localhost:3001
# Replace with: openssl rand -hex 16
GRAFANA_ADMIN_PASSWORD=replace-with-strong-password

# ── JWT Keys ──────────────────────────────────────────────────────────────────
# Generate RSA key pair before first run (keys are gitignored):
#   mkdir -p keys
#   openssl genrsa -out keys/private.pem 2048
#   openssl rsa -in keys/private.pem -pubout -out keys/public.pem
#
# Keys are mounted read-only into containers at /keys/
# private.pem → auth-service only (signs tokens)
# public.pem  → all services (verifies tokens)

# ── Environment tag ───────────────────────────────────────────────────────────
# Used for metric labels and log context. One of: local | staging | production
ENVIRONMENT=local

# ── Download service base URL ─────────────────────────────────────────────────
# Public base URL used when constructing signed download URLs.
# For local dev: http://localhost:8083
# For production: https://api.yourdomain.com
DOWNLOAD_BASE_URL=http://localhost:8083
