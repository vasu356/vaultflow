{
  "title": "VaultFlow Platform Overview",
  "uid": "vaultflow-overview",
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Upload Throughput (bytes/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(upload_bytes_total[5m])",
          "legendFormat": "Upload bytes/sec"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 2,
      "title": "Download Throughput (bytes/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(download_bytes_total[5m])",
          "legendFormat": "Download bytes/sec"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "id": 3,
      "title": "HTTP Request Rate by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count[5m])) by (application)",
          "legendFormat": "{{application}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 4,
      "title": "HTTP p99 Latency by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket[5m])) by (application, le))",
          "legendFormat": "{{application}} p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.5 },
            { "color": "red", "value": 1.0 }
          ]
        }}
      }
    },
    {
      "id": 5,
      "title": "HTTP Error Rate (4xx + 5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"4..|5..\"}[5m])) by (application, status)",
          "legendFormat": "{{application}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "red" } }
      }
    },
    {
      "id": 6,
      "title": "Processing Pipeline - Events Processed",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "increase(processing_pipeline_completed_total[1h])",
          "legendFormat": "Processed (1h)"
        }
      ]
    },
    {
      "id": 7,
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "kafka_consumer_fetch_manager_records_lag_max",
          "legendFormat": "{{topic}} lag"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1000 },
            { "color": "red", "value": 10000 }
          ]
        }}
      }
    },
    {
      "id": 8,
      "title": "JVM Heap Usage by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\"} / jvm_memory_max_bytes{area=\"heap\"}",
          "legendFormat": "{{application}} heap%"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1, "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.75 },
            { "color": "red", "value": 0.90 }
          ]
        }}
      }
    },
    {
      "id": 9,
      "title": "Login Success/Failure Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "rate(auth_login_successes_total[5m])",
          "legendFormat": "Logins/sec (success)"
        },
        {
          "expr": "rate(auth_login_failures_total[5m])",
          "legendFormat": "Logins/sec (failure)"
        }
      ]
    },
    {
      "id": 10,
      "title": "Storage Deduplication Hit Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "rate(storage_dedup_hits_total[5m]) / rate(upload_files_total[5m]) * 100",
          "legendFormat": "Dedup %"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent" }
      }
    },
    {
      "id": 11,
      "title": "DB Connection Pool Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "targets": [
        {
          "expr": "hikaricp_connections_active / hikaricp_connections_max",
          "legendFormat": "{{application}} pool%"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.70 },
            { "color": "red", "value": 0.90 }
          ]
        }}
      }
    },
    {
      "id": 12,
      "title": "Virus Scan Results",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "targets": [
        { "expr": "increase(processing_virus_clean_total[24h])", "legendFormat": "Clean" },
        { "expr": "increase(processing_virus_infected_total[24h])", "legendFormat": "Infected" },
        { "expr": "increase(processing_virus_skipped_total[24h])", "legendFormat": "Skipped" }
      ]
    }
  ]
}
